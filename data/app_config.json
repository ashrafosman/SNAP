    {
      "id": "gold_qc_case_scores",
      "name": "gold_qc_case_scores",
      "domain": "Public Benefits",
      "system": "Databricks Unity Catalog",
      "description": "QC-ready case-level scoring table. One row per SNAP case. Powers the Case Queue, Dashboard risk metrics, and penalty exposure calculations.",
      "cadence": "Daily",
      "layer": "gold",
      "sources": [
        "silver_snap_linked_persons",
        "silver_household_profile",
        "silver_clinical_risk"
      ],
      "schema": [
        {
          "column": "case_id",
          "type": "STRING",
          "description": "SNAP case identifier"
        },
        {
          "column": "household_id",
          "type": "STRING",
          "description": "Household identifier"
        },
        {
          "column": "county_fips",
          "type": "STRING",
          "description": "County FIPS code"
        },
        {
          "column": "qc_score",
          "type": "INT",
          "description": "Composite QC risk score 0\u2013100 (100 = highest risk)"
        },
        {
          "column": "priority",
          "type": "STRING",
          "description": "HIGH | MEDIUM | LOW based on qc_score thresholds"
        },
        {
          "column": "error_type",
          "type": "STRING",
          "description": "Primary error type driving the score"
        },
        {
          "column": "estimated_error_amount",
          "type": "DOUBLE",
          "description": "Estimated dollar value of the error ($)"
        },
        {
          "column": "flags",
          "type": "ARRAY",
          "description": "Array of signal codes that contributed to the score"
        },
        {
          "column": "benefit_amount",
          "type": "DOUBLE",
          "description": "Current monthly benefit allotment ($)"
        },
        {
          "column": "redetermination_date",
          "type": "DATE",
          "description": "Next redetermination date"
        },
        {
          "column": "case_status",
          "type": "STRING",
          "description": "active | under_review | resolved"
        },
        {
          "column": "scored_at",
          "type": "TIMESTAMP",
          "description": "Timestamp when score was last computed"
        }
      ]
    },
    {
      "id": "gold_cross_dataset_signals",
      "name": "gold_cross_dataset_signals",
