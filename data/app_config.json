          "column": "signal_id",
          "type": "STRING",
          "description": "Unique signal identifier"
        },
        {
          "column": "case_id",
          "type": "STRING",
          "description": "Affected SNAP case ID"
        },
        {
          "column": "household_id",
          "type": "STRING",
          "description": "Affected household ID"
        },
        {
          "column": "signal_type",
          "type": "STRING",
          "description": "death_match | medicaid_gap | unreported_birth | missed_deduction | adt_trigger | sdoh_change"
        },
        {
          "column": "severity",
          "type": "STRING",
          "description": "HIGH | MEDIUM | LOW"
        },
        {
          "column": "description",
          "type": "STRING",
          "description": "Human-readable description of the anomaly"
        },
        {
          "column": "datasets_involved",
