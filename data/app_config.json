          "description": "Source dataset IDs that produced this signal"
        },
        {
          "column": "estimated_impact",
          "type": "DOUBLE",
          "description": "Estimated dollar impact if signal is a true error ($)"
        },
        {
          "column": "status",
          "type": "STRING",
          "description": "open | under_review | resolved | dismissed"
        },
        {
          "column": "detected_at",
          "type": "TIMESTAMP",
          "description": "When this signal was first detected"
        },
        {
          "column": "resolved_at",
          "type": "TIMESTAMP",
          "description": "When this signal was resolved (null if open)"
        }
      ]
    },
    {
      "id": "gold_deduction_audit",
      "name": "gold_deduction_audit",
      "domain": "Public Benefits",
      "system": "Databricks Unity Catalog",
      "description": "Missed medical expense deduction audit. Identifies SNAP cases where EHR/ADT data indicates a person qualifies for a deduction that is not being applied \u2014 systematic underpayments.",
      "cadence": "Weekly",
      "layer": "gold",
      "sources": [
        "silver_clinical_risk",
        "gold_qc_case_scores"
      ],
      "schema": [
        {
          "column": "audit_id",
          "type": "STRING",
          "description": "Unique audit record ID"
        },
        {
          "column": "case_id",
          "type": "STRING",
          "description": "SNAP case ID"
        },
        {
          "column": "person_id",
          "type": "STRING",
          "description": "Affected person within the household"
        },
        {
          "column": "qualifying_icd10_codes",
          "type": "ARRAY",
          "description": "ICD-10 codes that qualify for medical expense deduction"
        },
        {
          "column": "disability_qualified",
          "type": "BOOLEAN",
          "description": "True if person meets SNAP disability definition"
        },
        {
          "column": "current_deduction_amount",
          "type": "DOUBLE",
          "description": "Medical deduction currently applied on SNAP case ($)"
        },
        {
          "column": "estimated_eligible_amount",
          "type": "DOUBLE",
          "description": "Estimated deduction person is eligible for ($)"
        },
        {
          "column": "gap_amount",
          "type": "DOUBLE",
          "description": "estimated_eligible_amount minus current_deduction_amount ($)"
        },
        {
          "column": "benefit_impact",
          "type": "DOUBLE",
          "description": "Estimated monthly benefit increase if gap corrected ($)"
        },
        {
          "column": "priority",
          "type": "STRING",
          "description": "HIGH | MEDIUM | LOW based on gap_amount"
        },
        {
          "column": "computed_at",
          "type": "TIMESTAMP",
